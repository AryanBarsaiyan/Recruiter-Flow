# Future Scope Backend – sample environment variables
# Copy this file to .env and set values. Do not commit .env.
#
# Usage:
#   Windows (PowerShell):  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }; .\mvnw.cmd spring-boot:run
#   Windows (cmd):        for /f "usebackq tokens=*" %i in (".env") do set %i  (then run mvnw.cmd spring-boot:run)
#   Linux/macOS:          set -a && source .env && set +a && ./mvnw spring-boot:run
#   Or pass as system properties:  mvnw spring-boot:run -Dspring.datasource.url=...
#
# Spring Boot maps env vars automatically when they use relaxed binding, e.g.:
#   SPRING_DATASOURCE_URL  -> spring.datasource.url
#   SPRING_DATASOURCE_USERNAME -> spring.datasource.username
#   JWT_SECRET (if you add a custom property) -> use application-local.yml for custom names

# --- Database (PostgreSQL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/future_scope_dev
SPRING_DATASOURCE_USERNAME=future_scope
SPRING_DATASOURCE_PASSWORD=future_scope

# --- JWT (use a long random secret in production; base64 recommended) ---
# Generate: openssl rand -base64 32
SECURITY_JWT_SECRET=your-base64-encoded-256-bit-secret-here
SECURITY_JWT_ACCESS_TOKEN_MINUTES=60

# --- App (optional) ---
APP_BASE_URL=https://app.example.com
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=15
APP_RATE_LIMIT_INTERVIEW_REQUESTS_PER_MINUTE=30
APP_RATE_LIMIT_PROCTORING_SESSION_REQUESTS_PER_MINUTE=10
APP_RATE_LIMIT_PROCTORING_EVENTS_PER_MINUTE=120

# --- Server (optional) ---
SERVER_PORT=8080
